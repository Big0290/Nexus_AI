{
  "name": "metacognitive-orchestrator",
  "private": true,
  "workspaces": [
    "brain-core",
    "agents",
    "ui",
    "server"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev": "concurrently -n server,ui -c blue,green \"npm run dev --workspace=server\" \"wait-on tcp:127.0.0.1:8787 && npm run dev --workspace=ui\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3",
    "wait-on": "^8.0.1"
  },
  "engines": {
    "node": ">=20"
  }
}
