# Gemini (optional — mock mode if unset). The server loads `.env` from this repo root or `server/` via dotenv.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Set to 1 to use Gemini text embeddings for outcome recall (otherwise TF-IDF lexical similarity)
GEMINI_EMBEDDINGS=0
GEMINI_EMBEDDING_MODEL=text-embedding-004

# API server
PORT=8787
DATA_DIR=./data
ORCHESTRATOR_ID=brain-1
# Optional: require Authorization: Bearer <key> or X-API-Key (UI stores in localStorage as nexus_api_key; SSE uses ?api_key=)
NEXUS_API_KEY=
# Session transcripts: DATA_DIR/sessions/<sessionId>.json (multi-turn prompts)
